server:
  port: 8080
  servlet:
    context-path: /

spring:
  application:
    name: dms-server

  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/dms_db?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Tokyo&useSSL=false
    username: root
    password: YOUR_DB_PASSWORD

  redis:
    host: localhost
    port: 6379
    database: 0
    timeout: 3000ms
    lettuce:
      pool:
        max-active: 8
        max-wait: -1ms
        max-idle: 8
        min-idle: 0

  jackson:
    date-format: yyyy-MM-dd HH:mm:ss
    time-zone: Asia/Tokyo
    serialization:
      write-dates-as-timestamps: false

mybatis:
  mapper-locations: classpath:mapper/*.xml
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.slf4j.Slf4jImpl
    default-fetch-size: 100
    default-statement-timeout: 30

logging:
  level:
    com.dms.server: DEBUG
    org.springframework.web: INFO
